# ─── African Strikers FC — Environment Variables ───
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Server ───────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Site URL (used in emails and CORS) ──────────
# Your production domain (no trailing slash)
SITE_URL=https://africanstrikers.com

# ─── CORS ─────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=https://africanstrikers.com

# ─── Admin Credentials ────────────────────────────
# Only used on FIRST run to seed the admin account
ADMIN_USER=admin
ADMIN_PASS=strikers2026

# ─── Email (SMTP) ────────────────────────────────
# If not set, uses Ethereal test account (dev only)
# For Gmail: use an App Password, not your real password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="African Strikers FC <your-email@gmail.com>"
