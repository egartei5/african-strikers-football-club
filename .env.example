# ─── African Strikers FC — Environment Variables ───
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Server ───────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Site URL (used in emails and CORS) ──────────
# Your production domain (no trailing slash)
SITE_URL=https://african-strikers-football-club-production.up.railway.app

# ─── CORS ─────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=https://african-strikers-football-club-production.up.railway.app

# ─── Admin Credentials ────────────────────────────
# Only used on FIRST run to seed the admin account
ADMIN_USER=admin
ADMIN_PASS=strikers2026

# ─── Admin Notification Email ────────────────────
# Contact form submissions are sent here
ADMIN_EMAIL=your-admin-email@gmail.com

# ─── Email (SMTP) ────────────────────────────────
# REQUIRED for emails to work in production.
# Without these, the app falls back to Ethereal (fake inbox).
#
# For Gmail:
#   1. Enable 2-Step Verification on your Google account
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Use that App Password as SMTP_PASS (NOT your regular Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="African Strikers FC <your-email@gmail.com>"
